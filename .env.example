# ============================================================
# 2026 투자학교 포트폴리오 — 환경 변수 예시
# 이 파일을 복사해 .env.local 로 이름 변경 후 실제 값을 채우세요.
# .env.local 은 절대 Git에 커밋하지 마세요.
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# ── (선택) Supabase Service Role ──────────────────────────────
# 서버사이드 Admin 작업이 필요할 때만 사용 (절대 클라이언트 노출 금지)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── (선택) 외부 주가 API ──────────────────────────────────────
# 현재는 Yahoo Finance / CoinGecko 무료 API를 사용하므로 키 불필요
# 향후 유료 플랜 사용 시 아래에 추가
# YAHOO_FINANCE_API_KEY=
# COINGECKO_API_KEY=

# ── (선택) 토스증권 Open API — 실거래 계정 ⚠️ ────────────────────
# ⚠️ 실거래(live) 키입니다. 실제 주문·자금 이동이 가능 → 절대 커밋·클라이언트 노출 금지.
#     서버 사이드(라우트 핸들러)에서만 사용. .env.local 과 Vercel 환경변수에만 본인이 직접 입력.
#     tsck_live_ / tssk_live_ 접두어 = 실거래. 모의투자는 별도 sandbox 키 권장.
# TOSS_API_KEY=tsck_live_xxxxxxxxxxxxxxxx
# TOSS_SECRET_KEY=tssk_live_xxxxxxxxxxxxxxxx
# TOSS_TRADING_ENABLED=false   # 실제 주문 실행 게이트(기본 false=조회 전용)
