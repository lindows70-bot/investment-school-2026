{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "buildCommand": "npm run build",
  "devCommand":   "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",

  "regions": ["icn1"],

  "functions": {
    "src/app/api/stock-price/route.ts":         { "maxDuration": 30 },
    "src/app/api/financials/route.ts":           { "maxDuration": 45 },
    "src/app/api/stock-info/route.ts":           { "maxDuration": 30 },
    "src/app/api/stock-price-history/route.ts":  { "maxDuration": 30 },
    "src/app/api/school-league/route.ts":        { "maxDuration": 45 },
    "src/app/api/lynch-classify/route.ts":       { "maxDuration": 20 },
    "src/app/api/lynch-batch/route.ts":          { "maxDuration": 45 },
    "src/app/api/market-indices/route.ts":       { "maxDuration": 20 },
    "src/app/api/macro-data/route.ts":           { "maxDuration": 30 },
    "src/app/api/fred/route.ts":                 { "maxDuration": 30 },
    "src/app/api/fedwatch/route.ts":             { "maxDuration": 20 },
    "src/app/api/shadow-13f/route.ts":           { "maxDuration": 45 },
    "src/app/api/nps-portfolio/route.ts":        { "maxDuration": 60 },
    "src/app/api/cron/morning-briefing/route.ts":{ "maxDuration": 300 },
    "src/app/api/cron/school-index/route.ts":    { "maxDuration": 120 },
    "src/app/api/correlation-matrix/route.ts":   { "maxDuration": 60 },
    "src/app/api/lynch-earnings-tracer/route.ts":{ "maxDuration": 45 },
    "src/app/api/guidance-radar/route.ts":       { "maxDuration": 60 },
    "src/app/api/dividend-explorer/route.ts":    { "maxDuration": 30 },
    "src/app/api/macro-ai-picks/route.ts":       { "maxDuration": 120 },
    "src/app/api/cron/satellite-scores/route.ts":{ "maxDuration": 120 },
    "src/app/api/market-flow-kr/route.ts":       { "maxDuration": 120 },
    "src/app/api/cron/market-flow-kr/route.ts":  { "maxDuration": 120 },
    "src/app/api/blackrock/route.ts":            { "maxDuration": 120 }
  },

  "crons": [
    { "path": "/api/nps-portfolio", "schedule": "0 18 * * *" },
    { "path": "/api/shadow-13f?ticker=AAPL&name=Apple%20Inc&market=US", "schedule": "0 18 * * *" },
    { "path": "/api/cron/school-index", "schedule": "0 19 * * *" },
    { "path": "/api/cron/morning-briefing", "schedule": "0 20 * * *" },
    { "path": "/api/macro-ai-picks?refresh=1", "schedule": "0 19 * * 1" },
    { "path": "/api/cron/satellite-scores", "schedule": "30 18 * * *" },
    { "path": "/api/cron/market-flow-kr", "schedule": "0 11 * * 1-5" },
    { "path": "/api/blackrock?refresh=1", "schedule": "0 21 * * 1" },
    { "path": "/api/cron/timing-watch", "schedule": "30 23 * * *" }
  ],

  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control",              "value": "no-store, no-cache, must-revalidate" },
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "X-Content-Type-Options",     "value": "nosniff" }
      ]
    },
    {
      "source": "/api/fred",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=43200, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/api/macro-data",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=43200, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",         "value": "DENY" },
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "Referrer-Policy",         "value": "strict-origin-when-cross-origin" },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ],

  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/stock-price?ticker=AAPL&market=US"
    }
  ]
}
